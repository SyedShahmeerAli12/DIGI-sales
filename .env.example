# Used by docker-compose.yml to bake the backend URL into the frontend build.
# On the VPS, set this to the HTTPS domain Caddy serves (see SITE_DOMAIN below) —
# mic/voice input requires a secure context (HTTPS), plain HTTP won't work.
BACKEND_PUBLIC_URL=https://your-vps-ip.sslip.io

# The public hostname Caddy auto-provisions a free HTTPS cert for. No real domain
# needed: sslip.io resolves "<your-vps-ip>.sslip.io" straight back to your IP, and
# Let's Encrypt issues a real trusted cert for it. Requires ports 80+443 open.
SITE_DOMAIN=your-vps-ip.sslip.io
