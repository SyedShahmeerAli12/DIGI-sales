# OpenAI
OPENAI_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-large
CHAT_MODEL=gpt-4o

# Qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=digi_knowledge_base

# Auth
JWT_SECRET=replace-with-a-long-random-string
# 8760 = 1 year, so a client demo session doesn't get logged out mid-use
JWT_EXPIRY_HOURS=8760
APP_USERNAME=admin@digitrends.ai
# Generate with: python -m app.scripts.hash_password "your-demo-password"
APP_PASSWORD_HASH=

# CORS — set to the frontend's real origin in production, e.g. http://your-vps-ip:3000
ALLOWED_ORIGINS=http://localhost:3000
